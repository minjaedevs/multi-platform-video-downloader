@echo off
cd /d "%~dp0"
powershell -NoProfile -ExecutionPolicy Bypass -Command "$runtime = Join-Path (Get-Location) '.runtime'; $urlPath = Join-Path $runtime 'ngrok_url.txt'; $tokenPath = Join-Path $runtime 'api_token.txt'; $url = ''; $token = ''; if (Test-Path $urlPath) { $url = ((Get-Content $urlPath -Raw -ErrorAction SilentlyContinue) -as [string]).Trim() }; if (Test-Path $tokenPath) { $token = ((Get-Content $tokenPath -Raw -ErrorAction SilentlyContinue) -as [string]).Trim() }; if (-not $url) { try { $tunnels = Invoke-RestMethod 'http://127.0.0.1:4040/api/tunnels' -TimeoutSec 3; $url = @($tunnels.tunnels | Where-Object { $_.proto -eq 'https' } | Select-Object -First 1 -ExpandProperty public_url); if ($url) { New-Item -ItemType Directory -Force -Path $runtime | Out-Null; Set-Content -Path $urlPath -Value $url } } catch {} }; if (-not $token) { Write-Host 'Missing .runtime\api_token.txt. Run backend first:'; Write-Host '  .\run_public_api_test.cmd'; exit 1 }; if (-not $url) { Write-Host 'Missing ngrok public URL. Run ngrok in another terminal first:'; Write-Host '  .\run_ngrok_8787.cmd'; Write-Host ''; Write-Host 'If ngrok is already open, wait a few seconds then run this command again.'; exit 1 }; Write-Host ''; Write-Host 'Client demo link:'; Write-Host ('https://minjaedevs.github.io/multi-platform-video-downloader/?api=' + $url + '&token=' + $token); Write-Host ''; Write-Host 'API:'; Write-Host $url; Write-Host ''; Write-Host 'Admin local:'; Write-Host 'http://127.0.0.1:8787/admin'"
